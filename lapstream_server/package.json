{
  "name": "lapstream_server",
  "version": "1.0.0",
  "private": true,
  "description": "LapStream backend (Express + TypeScript + Drizzle ready)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@types/inquirer": "^9.0.9",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "express": "^5.2.1",
    "inquirer": "^13.2.5",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.5",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.1"
  }
}
